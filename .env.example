# ═══════════════════════════════════════════════════════════════
# SignalSmith AI — Environment Configuration
# Copy to .env and fill in your values. Never commit .env.
# Full guide: docs/SPLUNK_SETUP.md
# ═══════════════════════════════════════════════════════════════

# ── Splunk host ──────────────────────────────────────────────
SPLUNK_HOST=localhost

# Splunk Web UI — Settings → Server settings → General settings
SPLUNK_WEB_PORT=8005
SPLUNK_WEB_SCHEME=http

# Splunk REST API / MCP — check Splunk MCP Server page for your port
SPLUNK_API_PORT=8090
SPLUNK_API_SCHEME=https

# HTTP Event Collector (optional — faster bootstrap ingest)
SPLUNK_HEC_PORT=8088
SPLUNK_HEC_TOKEN=

# Splunk credentials (demo default — change for your instance)
SPLUNK_USERNAME=admin
SPLUNK_PASSWORD=changeme123

# ── Indexes (shadow pattern) ─────────────────────────────────
SPLUNK_BASELINE_INDEX=signalsmith_baseline
SPLUNK_CANDIDATE_INDEX=signalsmith_candidate

# ── Splunk MCP Server (recommended for hackathon) ────────────
# Copy endpoint from Splunk → MCP Server → Endpoints
# e.g. https://localhost:8090/services/mcp
SPLUNK_MCP_URL=

# Encrypted token from MCP Server → Create MCP Encrypted Token
SPLUNK_MCP_TOKEN=

# Require live Splunk (false = allow offline JSON fallback for tests)
REQUIRE_SPLUNK=true

# Max events exported during bootstrap SPL query
PROFILE_EXPORT_LIMIT=25000

# ── SignalSmith Mentor (optional) ────────────────────────────
# https://aistudio.google.com/apikey
# Mentor works without this — template SPL fallback still available
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_ENABLED=true

# ── Custom detections (any Splunk workload — not limited to demo) ─
# Copy config/detections.example.json → config/detections.json
SIGNALSMITH_DETECTIONS_FILE=
# false = use ONLY your detections, not the built-in e-commerce demo set
SIGNALSMITH_INCLUDE_DEMO_DETECTIONS=true

# ── App ──────────────────────────────────────────────────────
# Backend serves UI + API on this port (scripts/start.ps1)
VITE_API_URL=http://localhost:8080